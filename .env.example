# Google AI Studio / Vertex AI key for Gemini. Without it the app runs in
# mock-intake mode: the UI works end to end with canned parses so the demo
# never breaks, and a banner tells you AI parsing is mocked.
GEMINI_API_KEY=

# Model selection (optional). Intake is the hard perception job (Odia/Hindi
# voice, handwriting) so it defaults to Pro; the brief is easy summarization
# so it defaults to Flash for speed and gentler rate limits.
# GEMINI_INTAKE_MODEL=gemini-2.5-pro
# GEMINI_BRIEF_MODEL=gemini-2.5-flash
# GEMINI_MODEL overrides BOTH of the above if set:
# GEMINI_MODEL=gemini-2.5-flash
